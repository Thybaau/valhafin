# API URL configuration
# 
# Vite loads environment files in this order (higher priority first):
# 1. .env.[mode].local (e.g., .env.production.local) - local overrides, not in git
# 2. .env.[mode] (e.g., .env.production or .env.development)
# 3. .env.local - local overrides, not in git
# 4. .env - default fallback
#
# Modes:
# - 'development' when running 'npm run dev'
# - 'production' when running 'npm run build'
#
# For production (Kubernetes deployment):
# - Use .env.production with VITE_API_URL=/api
# - The Ingress controller routes /api requests to the backend service
# - This is used during Docker build
# 
# For local development:
# - Use .env.development with VITE_API_URL=http://localhost:8080/api
# - Direct connection to local backend
# 
# For local overrides (not committed):
# - Create .env.local or .env.development.local
# 
VITE_API_URL=/api
